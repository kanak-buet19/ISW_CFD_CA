FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      PhaseFieldProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// V_incident	(0 1 0);//(0 1 0);//NORMALISED IN CODE
V_incident (0 1 0) ; 

timeVsLaserPosition
{
    file    "$FOAM_CASE/constant/timeVsLaserPosition";
    outOfBounds clamp;
}

timeVsLaserPower
{
    file    "$FOAM_CASE/constant/timeVsLaserPower";
    outOfBounds clamp;
}

// Optional square pulse gate for pulsed LBW. When enabled, the value from
// timeVsLaserPower is treated as the on-pulse power.
// pulseLaser true;
// pulseFrequency 10;       // Hz
// pulseDuration 0.0071;    // s
// pulseStart 0;            // s
// pulseEnd 5;              // s
// pulseOffPower 0;         // W

laserRadius 50e-6; //356µm diameter

N_sub_divisions	1;



wavelength	1.064e-6;
e_num_density	5.8e29;

Radius_Flavour	2.0;

PowderSim false;
